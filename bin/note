#!/usr/bin/env ruby
# frozen_string_literal: true
#
# usage: bin/note find [query] [--type T --realm R --mission M --target X --tag X --status S]
#
# Search the engineering-notes corpus (workshop/notes/). Structured filters and a free-text
# query compose: filters narrow first, then the query searches within. Output is plain,
# greppable blocks — one note per two lines (path + facets, then title).

require_relative "../lib/workshop"
require "optparse"
require "fileutils"
require "open3"

# WORKSHOP_ROOT is where the framework (templates, lib) lives — derived from this script.
# WORKSHOP_CONTENT_DIR is where practice content (notes, missions) lives. Resolve it through
# the SAME config layering the bin/ shell scripts use (.workshoprc then .workshoprc.local),
# so this Ruby CLI honors a per-machine content dir without the user exporting it in their
# shell profile. Falls back to the framework root when nothing sets it.
WORKSHOP_ROOT = File.expand_path("..", __dir__)

def resolve_content_dir(root)
  script = <<~SH
    [ -f "$WS_ROOT/.workshoprc" ] && . "$WS_ROOT/.workshoprc"
    [ -f "$WS_ROOT/.workshoprc.local" ] && . "$WS_ROOT/.workshoprc.local"
    printf '%s' "${WORKSHOP_CONTENT_DIR:-$WS_ROOT}"
  SH
  out, status = Open3.capture2({ "WS_ROOT" => root }, "bash", "-c", script)
  status.success? && !out.strip.empty? ? File.expand_path(out.strip) : root
rescue StandardError
  root
end

WORKSHOP_CONTENT_DIR = resolve_content_dir(WORKSHOP_ROOT)
NOTES_DIR = File.join(WORKSHOP_CONTENT_DIR, "notes")

def find(argv)
  filters = {}
  parser = OptionParser.new do |o|
    o.on("--type T") { |v| filters[:type] = v }
    o.on("--realm R") { |v| filters[:realm] = v }
    o.on("--mission M") { |v| filters[:mission] = v }
    o.on("--target X") { |v| filters[:target] = v }
    o.on("--tag X") { |v| filters[:tag] = v }
    o.on("--status S") { |v| filters[:status] = v }
  end
  parser.parse!(argv)
  query = argv.join(" ")

  corpus = Workshop::NotesCorpus.new(NOTES_DIR)
  notes = corpus.where(**filters)
  notes = corpus.search(query, notes: notes)

  notes.each { |note| puts render(note) }
end

def render(note)
  scope = note.slice ? "#{note.mission}/#{note.slice}" : note.mission
  facets = [note.type, note.realm, scope]
  facets << "target:#{note.target}" if note.target
  facets << note.status
  facets << note.tags.join(", ") unless note.tags.empty?

  rel = note.path.delete_prefix("#{WORKSHOP_CONTENT_DIR}/")
  "#{rel}  #{facets.join(' · ')}\n  #{note.title}"
end

def index
  corpus = Workshop::NotesCorpus.new(NOTES_DIR)
  FileUtils.mkdir_p(NOTES_DIR)
  path = File.join(NOTES_DIR, "INDEX.md")
  File.write(path, Workshop::NotesIndex.new(corpus).render)
  puts "Wrote #{path.delete_prefix("#{WORKSHOP_CONTENT_DIR}/")} (#{corpus.notes.size} notes)"
end

def new_note(argv)
  attrs = {}
  explicit_mission = nil
  parser = OptionParser.new do |o|
    o.on("--type T") { |v| attrs[:type] = v }
    o.on("--realm R") { |v| attrs[:realm] = v }
    o.on("--mission M") { |v| explicit_mission = v }
    o.on("--target X") { |v| attrs[:target] = v }
    o.on("--slice S") { |v| attrs[:slice] = v }
    o.on("--tags T") { |v| attrs[:tags] = v.split(",").map(&:strip) }
    o.on("--status S") { |v| attrs[:status] = v }
  end
  parser.parse!(argv)
  attrs[:title] = argv.join(" ")
  abort "title required: bin/note new \"<title>\" [--type ...]" if attrs[:title].empty?

  corpus = Workshop::NotesCorpus.new(NOTES_DIR)
  template = File.read(File.join(WORKSHOP_ROOT, "templates", "note.md.tmpl"))
  scaffold = Workshop::NoteScaffold.new(template: template, clock: Date, mission: active_mission(explicit_mission))
  result = scaffold.build(attrs, existing_slugs: corpus.notes.map(&:slug))

  path = File.join(NOTES_DIR, "#{result[:slug]}.md")
  abort "refusing to overwrite #{path}" if File.exist?(path)
  FileUtils.mkdir_p(NOTES_DIR)
  File.write(path, result[:content])
  puts "Created #{path.delete_prefix("#{WORKSHOP_CONTENT_DIR}/")}"
  puts "Run bin/note index"
end

# Active mission: explicit --mission, else inferred by walking up from the cwd to a MISSION.md.
def active_mission(explicit)
  if explicit
    Workshop::Mission.find(WORKSHOP_CONTENT_DIR, explicit) ||
      Workshop::Mission.new(name: explicit, source: "")
  else
    infer_mission_from_cwd
  end
end

def infer_mission_from_cwd
  dir = Dir.pwd
  while dir.start_with?(WORKSHOP_CONTENT_DIR) && dir != File.dirname(dir)
    md = File.join(dir, "MISSION.md")
    return Workshop::Mission.new(name: File.basename(dir), source: File.read(md)) if File.exist?(md)

    dir = File.dirname(dir)
  end
  nil
end

command = ARGV.shift

case command
when "find"
  find(ARGV)
when "index"
  index
when "new"
  new_note(ARGV)
else
  warn "usage: bin/note <new|find|index> ..."
  exit 64
end
